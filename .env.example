# ==========================================
# 议论文评改智能体 - 本地环境变量配置
# ==========================================

# --- OCR 服务配置 (Paddle OCR) ---
OCR_API_URL=https://你的_paddle_ocr_接口地址
OCR_API_TOKEN=你的_paddle_ocr_token

# --- 大模型服务配置 (OpenAI 兼容接口) ---
LLM_API_URL=https://你的_openai_代理地址/v1
LLM_API_KEY=你的_openai_token
LLM_MODEL_NAME=模型名称

# --- 项目运行配置 ---
ENVIRONMENT=development
DEBUG=True